# Client (Vite) — public in browser; use anon key only, never service_role.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-side only (Edge Functions, scripts). Do NOT prefix with VITE_.
# Never import this in React/browser code.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
